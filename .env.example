# Drug Discovery Agent — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Required: Anthropic API key for Claude (get one at https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Override default Claude model (default: claude-sonnet-4-6)
# AGENT_MODEL=claude-sonnet-4-6

# Optional: Override max agentic loop iterations (default: 25)
# AGENT_MAX_ITERATIONS=25
